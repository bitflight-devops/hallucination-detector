  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bitflight-devops/hallucination-detector/issues"
  },
  "homepage": "https://github.com/bitflight-devops/hallucination-detector#readme",
  "engines": {
    "node": ">=22.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "octokit": "^5.0.5",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "undici": "^7.24.0",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "minimatch": ">=10.2.3",
    "lodash": ">=4.18.1",
    "lodash-es": ">=4.18.1",
    "handlebars": ">=4.7.9",
    "picomatch": ">=2.3.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch": ">=10.2.3",
